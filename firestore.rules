rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {

          function isStaff() {
                  return request.auth != null &&
                         (
                                      request.auth.token.email == 'root@tddetailed.admin' ||
                                                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Detailer', 'Owner']
                          );
          }

              match /bookings/{id} {
                      // Signed-in users can create bookings linked to their own account
                            // with verified profile details.
                                  allow create: if
                                          request.auth != null &&
                                                  request.resource.data.bookedByUid == request.auth.uid &&
                                                          request.resource.data.bookedByEmail is string &&
                                                                  request.resource.data.bookedByEmail.size() > 0 &&
                                                                          request.resource.data.customerName is string &&
                                                                                  request.resource.data.customerName.size() > 0 &&
                                                                                          request.resource.data.phone is string &&
                                                                                                  request.resource.data.phone.size() > 0 &&
                                                                                                          request.resource.data.address is string &&
                                                                                                                  request.resource.data.address.size() > 0 &&
                                                                                                                          request.resource.data.date is string &&
                                                                                                                                  request.resource.data.date.size() > 0 &&
                                                                                                                                          request.resource.data.time is string &&
                                                                                                                                                  request.resource.data.time.size() > 0 &&
                                                                                                                                                          request.resource.data.status == "pending";

                                                                                                                                                                // Staff can read all bookings; users can read their own bookings.
                                                                                                                                                                      allow read: if
                                                                                                                                                                              isStaff() ||
                                                                                                                                                                                      (request.auth != null && resource.data.bookedByUid == request.auth.uid);
                                                                                                                                                                                            allow update, delete: if isStaff();
              }

                  match /pricing/{id} {
                          // Pricing is publicly readable for website display.
                                allow read: if true;

                                      // Staff can manage pricing rows from dashboard.
                                            allow create: if isStaff();
                                                  allow update: if isStaff();
                                                        allow delete: if false;
                  }

                      match /galleryItems/{id} {
                              // Gallery is public for homepage display.
                                    allow read: if true;

                                          // Staff can manage gallery content.
                                                allow create, update, delete: if isStaff();
                      }

                          match /reviews/{id} {
                                  // Reviews are public for homepage display.
                                        allow read: if true;

                                              // Staff can manage curated review entries.
                                                    allow create, update, delete: if isStaff();
                          }

                              match /siteNews/{id} {
                                      // Site updates are public for homepage panel.
                                            allow read: if true;

                                                  // Staff can manage update posts.
                                                        allow create, update, delete: if isStaff();
                              }

                                  match /users/{uid} {
                                          // Signed-in users can create their own user profile document.
                                                allow create: if
                                                        (
                                                                    request.auth != null &&
                                                                              request.auth.uid == uid &&
                                                                                        request.resource.data.uid == request.auth.uid &&
                                                                                                  request.resource.data.email is string &&
                                                                                                            request.resource.data.name is string &&
                                                                                                                      request.resource.data.role == 'Standard'
                                                        ) || (
                                                                    request.auth != null &&
                                                                              request.auth.uid == uid &&
                                                                                        request.auth.token.email == 'root@tddetailed.admin' &&
                                                                                                  request.resource.data.uid == request.auth.uid &&
                                                                                                            request.resource.data.email == 'root@tddetailed.admin' &&
                                                                                                                      request.resource.data.role == 'Owner'
                                                        );

                                                              // Signed-in users can read their own profile; staff can read all.
                                                                    allow read: if (request.auth != null && request.auth.uid == uid) || isStaff();

                                                                          // Users can update limited profile fields but cannot self-change role/email/uid.
                                                                                allow update: if
                                                                                        (
                                                                                                    request.auth != null &&
                                                                                                              request.auth.uid == uid &&
                                                                                                                        request.resource.data.uid == resource.data.uid &&
                                                                                                                                  request.resource.data.email == resource.data.email &&
                                                                                                                                            request.resource.data.role == resource.data.role
                                                                                        ) || (
                                                                                                    request.auth != null &&
                                                                                                              request.auth.uid == uid &&
                                                                                                                        request.auth.token.email == 'root@tddetailed.admin' &&
                                                                                                                                  request.resource.data.uid == resource.data.uid &&
                                                                                                                                            request.resource.data.email == 'root@tddetailed.admin' &&
                                                                                                                                                      request.resource.data.role == 'Owner'
                                                                                        );

                                                                                              allow delete: if false;
                                  }

                                      // Deny everything else by default.
                                          match /{document=**} {
                                                  allow read, write: if false;
                                          }
    }
}

                                          }
                                                                                        )
                                                                                        )
                                                        )
                                                        )
                                  }
                              }
                          }
                      }
                  }
              }
                          )
          }
    }
}